// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash"
					}
				}
			},
			"extensions": [
				"expo.vscode-expo-tools",
				"github.vscode-github-actions"
			]
		}
	},
  "dockerComposeFile": "docker-compose.yml",
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1": {},
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"mounts": [
		"consistency=cached,source=${localEnv:USERPROFILE}/.aws,target=/root/.aws,type=bind", // add ${localEnv:HOME} to source for Linux
		"consistency=cached,source=${localEnv:USERPROFILE}/.expo,target=/root/.expo,type=bind", // add ${localEnv:HOME} to source for Linux
    "consistency=cached,source=${localWorkspaceFolder},target=${containerWorkspaceFolder},type=bind"
	],
	"name": "toad-reader-apps-staging",
	"postStartCommand": {
		"aws": "export AWS_PROFILE=BibleMesh",
		"git-commit-signing": "git config --global --unset gpg.ssh.program",
		"git-safe-directory": "git config --global --add safe.directory ${containerWorkspaceFolder}"
	},
	"runArgs": [
		"--name",
		"devcontainer-toad-reader-apps-staging"
	],
	"service": "ereader-frontend",
	"workspaceFolder": "/app"
}