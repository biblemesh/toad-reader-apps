{
  "cli": {
    "appVersionSource": "local",
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true
      },
      "env": {
        "channel": "development",
        "EXPO_UPDATES_ENABLE": "false"
      }
    },
    "staging": {
      "android": {
        "autoIncrement": "versionCode",
        "distribution": "internal"
      },
      "channel": "staging",
      "ios": {
        "autoIncrement": "buildNumber",
        "distribution": "store",
        "resourceClass": "m-medium"
      },
      "env": {
        "channel": "staging"
      }
    },
    "beta": {
      "distribution": "internal",
      "channel": "beta",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "channel": "beta"
      }
    },
    "production": {
      "android": {
        "autoIncrement": "versionCode"
      },
      "channel": "production",
      "ios": {
        "autoIncrement": "buildNumber",
        "resourceClass": "m-medium"
      },
      "env": {
        "channel": "production"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "releaseStatus": "draft",
        "track": "internal"
      }
    },
    "staging": {
      "android": {
        "releaseStatus": "draft",
        "track": "internal"
      }
    }
  }
}
